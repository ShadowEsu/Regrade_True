# Copy to server/.env — never commit real values.

# Server-only Gemini key (Google AI Studio). Never put this in Vite or the browser.
# In development you may leave this blank: the API still starts, but
# /v1/gemini/* returns 503 until you set a real key. Required in production.
GEMINI_API_KEY=

# Stripe Billing. Create two recurring monthly Prices in Stripe Dashboard.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STUDENT_PRICE_ID=
STRIPE_PRO_PRICE_ID=
BILLING_RETURN_URL=https://regradeapp.tech/app

# Option A — paste the entire service account JSON (Firebase console →
# Project settings → Service accounts) as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON=<one-line service account JSON>

# Option B — path to the downloaded .json file (easier for local dev):
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_JSON=

PORT=8787
NODE_ENV=development

# Comma-separated allowed browser origins. Use * only in local dev.
# Production (required — wildcard rejected): https://regrade.app,https://regrade.web.app
# Capacitor iOS/Android shells also need: capacitor://localhost,https://localhost
CORS_ORIGIN=*

# Required in production: comma-separated static API keys for POST /v1/feedback only.
# API_KEYS=your-long-random-key
