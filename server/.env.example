# Copy to server/.env — never commit real values.

# Server-only Gemini key (Google AI Studio). Never put this in Vite or the browser.
# In development you may leave this blank: the API still starts, but
# /v1/gemini/* returns 503 until you set a real key. Required in production.
GEMINI_API_KEY=

# Server-only Anthropic key (Claude). Optional — if unset, the hybrid pipeline
# silently falls back to Gemini-only. Never expose to the browser.
ANTHROPIC_API_KEY=

# Master switch for the hybrid pipeline. When "false", every analyze request
# uses Gemini only regardless of the user's stored preference. Useful as a
# kill switch during outages. Default: true.
HYBRID_ENABLED=true

# Option A — paste the entire service account JSON as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B — path to the downloaded .json file (easier for local dev):
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_JSON=

PORT=8787
NODE_ENV=development

# Comma-separated allowed browser origins. Use * only in local dev.
# Production (required — wildcard rejected): https://regrade.web.app,https://regrade.firebaseapp.com
CORS_ORIGIN=*

# Required in production: comma-separated static API keys for POST /v1/feedback only.
# API_KEYS=your-long-random-key
