# Copy to server/.env — never commit real values.

# Server-only Gemini key (Google AI Studio). Never put this in Vite or the browser.
GEMINI_API_KEY=

# Option A — paste the entire service account JSON as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B — path to the downloaded .json file (easier for local dev):
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_JSON=

PORT=8787
NODE_ENV=development

# Comma-separated allowed browser origins, or * for dev.
# Production example: https://regrade.web.app,https://regrade.firebaseapp.com
CORS_ORIGIN=*

# Optional: comma-separated static API keys for POST /v1/feedback only.
# API_KEYS=
