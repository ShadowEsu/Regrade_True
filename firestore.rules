rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Default Deny — nothing is readable/writable unless explicitly allowed below.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function boundedString(value, max) {
      return value is string && value.size() > 0 && value.size() <= max;
    }

    function optionalBoundedString(value, max) {
      return !(value is string) || (value.size() <= max);
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function authEmailMatches(dataEmail) {
      return request.auth.token.email != null && dataEmail == request.auth.token.email;
    }

    // --- Allowed field sets ---

    function isValidPlatformId(value) {
      return value is string && value in [
        'gradescope', 'canvas', 'google_classroom', 'google_drive', 'onedrive',
        'dropbox', 'apple_files', 'brightspace', 'moodle', 'blackboard',
        'turnitin', 'schoology', 'powerschool', 'teams_assignments', 'sakai',
        'itslearning', 'managebac', 'open_edx', 'fedena', 'teachmint',
        'dingtalk', 'lark', 'wecom', 'toddle', 'edunext', 'vidyalaya',
        'classter', 'infinite_campus', 'skyward', 'alma', 'veracross',
        'facts', 'clever', 'classlink', 'google_workspace', 'sharepoint',
        'box', 'email_import', 'paper'
      ];
    }

    // Chip lists (appeal tone / focus): short string ids, bounded count+length.
    // join() errors on non-string elements, which safely denies the write.
    function isValidChipList(value) {
      return value is list && value.size() <= 8 && value.join(',').size() <= 240;
    }

    function isValidStudyChecklist(value) {
      return value is list && value.size() <= 12 && value.join(',').size() <= 480;
    }

    function isValidUserProfileFields(data) {
      return optionalBoundedString(data.major, 128) &&
             optionalBoundedString(data.school, 256) &&
             optionalBoundedString(data.university, 256) &&
             optionalBoundedString(data.gradeLevel, 64) &&
             optionalBoundedString(data.gpa, 32) &&
             optionalBoundedString(data.appealGoal, 2000) &&
             optionalBoundedString(data.avatarUrl, 2048) &&
             (!('studentId' in data) || (data.studentId is string && data.studentId.size() <= 64)) &&
             (!('preferredPlatform' in data) || isValidPlatformId(data.preferredPlatform)) &&
             (!('aiEngine' in data) || (data.aiEngine is string && data.aiEngine in ['hybrid', 'gemini', 'claude'])) &&
             (!('onboardingComplete' in data) || data.onboardingComplete is bool) &&
             (!('tutorialComplete' in data) || data.tutorialComplete is bool) &&
             (!('analysisAlerts' in data) || data.analysisAlerts is bool) &&
             (!('autoMode' in data) || data.autoMode is bool) &&
             (!('automaticGradeDetection' in data) || data.automaticGradeDetection is bool) &&
             (!('accountRole' in data) || (data.accountRole is string && data.accountRole in ['student', 'supervisor'])) &&
             (!('studyChecklist' in data) || isValidStudyChecklist(data.studyChecklist)) &&
             (!('appealTone' in data) || isValidChipList(data.appealTone)) &&
             (!('appealFocus' in data) || isValidChipList(data.appealFocus)) &&
             (!('theme' in data) || (data.theme is string && data.theme in ['light', 'dark', 'system']));
    }

    function isValidUserCreate(data) {
      return data.keys().hasAll(['name', 'email', 'createdAt', 'updatedAt']) &&
             data.keys().hasOnly(['name', 'email', 'studentId', 'major', 'school',
                                   'university', 'gradeLevel', 'gpa', 'appealGoal',
                                   'appealTone', 'appealFocus', 'theme',
                                   'preferredPlatform', 'avatarUrl',
                                   'aiEngine', 'aiConsentAt', 'onboardingComplete', 'tutorialComplete', 'analysisAlerts', 'autoMode', 'automaticGradeDetection', 'studyChecklist', 'accountRole',
                                   'createdAt', 'updatedAt']) &&
             boundedString(data.name, 256) &&
             boundedString(data.email, 320) &&
             authEmailMatches(data.email) &&
             isValidUserProfileFields(data) &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidRawInputBlock(raw) {
      return raw is map &&
             raw.keys().hasOnly(['assignment', 'rubric', 'feedback']) &&
             (!('assignment' in raw) || optionalBoundedString(raw.assignment, 500000)) &&
             (!('rubric' in raw) || optionalBoundedString(raw.rubric, 500000)) &&
             (!('feedback' in raw) || optionalBoundedString(raw.feedback, 500000));
    }

    function isValidCaseCreate(data) {
      return data.keys().hasAll(['title', 'userId', 'createdAt', 'updatedAt', 'ref', 'status']) &&
             data.keys().hasOnly(['title', 'description', 'ref', 'status', 'progress',
                                   'evidenceLogged', 'facultyReview', 'userId',
                                   'analysis', 'rawInput', 'draftEmail', 'createdAt', 'updatedAt']) &&
             boundedString(data.title, 200) &&
             optionalBoundedString(data.description, 4000) &&
             boundedString(data.ref, 64) &&
             data.status is string && data.status in ['Under Review', 'Resolved', 'Draft Ready'] &&
             data.progress is number && data.progress >= 0 && data.progress <= 100 &&
             data.evidenceLogged is bool &&
             data.facultyReview is bool &&
             data.userId == request.auth.uid &&
             (!('analysis' in data) || data.analysis is map) &&
             (!('rawInput' in data) || isValidRawInputBlock(data.rawInput)) &&
             (!('draftEmail' in data) || optionalBoundedString(data.draftEmail, 64000)) &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidWaitlistCreate(data) {
      return data.keys().hasOnly(['email', 'createdAt', 'source']) &&
             boundedString(data.email, 320) &&
             data.email.matches('.+@.+\\..+') &&
             data.createdAt == request.time &&
             (!('source' in data) || boundedString(data.source, 64));
    }

    function isValidCaseUpdate(data, prior) {
      return data.userId == prior.userId &&
             data.createdAt == prior.createdAt &&
             data.updatedAt == request.time &&
             optionalBoundedString(data.title, 200) &&
             optionalBoundedString(data.description, 4000) &&
             optionalBoundedString(data.ref, 64) &&
             (data.status is string && data.status in ['Under Review', 'Resolved', 'Draft Ready']) &&
             data.progress is number && data.progress >= 0 && data.progress <= 100 &&
             data.evidenceLogged is bool &&
             data.facultyReview is bool &&
             (!('analysis' in data) || data.analysis is map) &&
             (!('rawInput' in data) || isValidRawInputBlock(data.rawInput)) &&
             (!('draftEmail' in data) || optionalBoundedString(data.draftEmail, 64000));
    }

    // --- Rules ---

    match /waitlist/{docId} {
      allow create: if isValidWaitlistCreate(incoming());
      allow read, update, delete: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserCreate(incoming());
      allow update: if isOwner(userId) &&
                      incoming().updatedAt == request.time &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().email == existing().email &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'name', 'major', 'school', 'university', 'gradeLevel', 'gpa',
                        'appealGoal', 'appealTone', 'appealFocus', 'theme',
                        'preferredPlatform', 'avatarUrl', 'aiEngine',
                        'aiConsentAt', 'onboardingComplete', 'tutorialComplete', 'analysisAlerts', 'autoMode', 'automaticGradeDetection', 'studyChecklist', 'accountRole', 'updatedAt'
                      ]) &&
                      optionalBoundedString(incoming().name, 256) &&
                      isValidUserProfileFields(incoming());
      allow delete: if isOwner(userId);
    }

    match /cases/{caseId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidCaseCreate(incoming()) && isValidId(caseId);
      allow update: if isSignedIn() &&
                      existing().userId == request.auth.uid &&
                      isValidCaseUpdate(incoming(), existing()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'title', 'description', 'status', 'progress',
                        'evidenceLogged', 'facultyReview', 'analysis', 'rawInput',
                        'draftEmail', 'updatedAt'
                      ]);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;

      // Milestones not used in app yet — deny until field rules exist.
      match /milestones/{milestoneId} {
        allow read, write: if false;
      }
    }
  }
}
