# Local only — copy to `.env` and fill in (never commit `.env`).
# Client Firebase config (VITE_* is embedded in the production JS bundle; restrict keys in Google Cloud).
# Gemini stays on the server: use `server/.env` with GEMINI_API_KEY.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Use (default) unless you created a named Firestore database
VITE_FIREBASE_FIRESTORE_DATABASE_ID=(default)
# Firebase App Check (reCAPTCHA Enterprise public site key). Turn server enforcement on only after this is deployed.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=

# Optional user-authorized file connections. These IDs are public OAuth app IDs,
# not secrets. Register the exact callback: https://YOUR_DOMAIN/oauth-callback.html
VITE_DROPBOX_APP_KEY=
VITE_MS_CLIENT_ID=

# Native subscriptions. These are public SDK keys and store product identifiers.
# Secret RevenueCat keys belong only in server/.env.
VITE_REVENUECAT_APPLE_API_KEY=
VITE_REVENUECAT_GOOGLE_API_KEY=
VITE_IAP_STUDENT_PRODUCT_ID=app.regrade.student.monthly
VITE_IAP_PRO_PRODUCT_ID=app.regrade.pro.monthly

# Stripe publishable key (pk_...). Secret key stays in server/.env only.
VITE_STRIPE_PUBLISHABLE_KEY=

# Production only: public URL of the Node API (omit for local dev; Vite proxies /api).
# VITE_API_BASE_URL=https://your-api.example.com

# Set automatically by `npm run build:desktop` for the Mac/Windows Electron shell.
# VITE_DESKTOP_SHELL=true
