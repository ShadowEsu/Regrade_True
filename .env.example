# Local only — copy to `.env` and fill in (never commit `.env`).
# Client Firebase config (VITE_* is embedded in the production JS bundle; restrict keys in Google Cloud).
# Gemini stays on the server: use `server/.env` with GEMINI_API_KEY.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Use (default) unless you created a named Firestore database
VITE_FIREBASE_FIRESTORE_DATABASE_ID=(default)

# Production only: public URL of the Node API (omit for local dev; Vite proxies /api).
# VITE_API_BASE_URL=https://your-api.example.com
