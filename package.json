{
  "name": "regrade",
  "private": true,
  "version": "1.0.0",
  "description": "Regrade — an AI-assisted grade-appeal assistant for students. Upload graded coursework, get a rubric-aware analysis, and draft an appeal letter.",
  "author": {
    "name": "Preston Jay Susanto"
  },
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://regradeapp.tech",
  "bugs": {
    "url": "mailto:regradeteam@gmail.com"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host localhost",
    "start": "vite --port=3000 --host localhost",
    "dev:api": "npm --prefix server run dev",
    "build": "vite build",
    "build:desktop": "VITE_DESKTOP_SHELL=true vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server/dist android/.gradle android/build android/app/build tmp tmp-ui-screenshots release",
    "clean:install": "rm -rf node_modules server/node_modules && npm ci && npm --prefix server ci",
    "lint": "tsc -p tsconfig.app.json --noEmit",
    "licenses": "npx --yes license-checker --production --json > THIRD_PARTY_LICENSES.json",
    "deploy:hosting": "npm run build && firebase deploy --only hosting:regrade-75d1a",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:regradeapp.tech": "bash scripts/deploy-regradeapp-tech.sh",
    "cap:sync": "npm run build && node scripts/prepare-capacitor.mjs && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "desktop": "node scripts/desktop-dev.mjs",
    "desktop:pack": "npm run build:desktop && electron-builder --mac --dir",
    "desktop:dmg": "npm run build:desktop && electron-builder --mac dmg zip",
    "test": "vitest run"
  },
  "build": {
    "appId": "app.regrade.desktop",
    "productName": "Regrade",
    "copyright": "Copyright 2026 Preston Jay Susanto",
    "directories": {
      "output": "release"
    },
    "extraMetadata": {
      "main": "electron/main.cjs",
      "dependencies": {}
    },
    "files": [
      "electron/**/*",
      "package.json",
      "!node_modules/**/*",
      "!server/**/*",
      "!src/**/*",
      "!ios/**/*",
      "!android/**/*",
      "!docs/**/*",
      "!dist/**/*"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "app-dist"
      }
    ],
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "icon": "public/logo.png"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/android": "^7.6.7",
    "@capacitor/app": "^7.1.2",
    "@capacitor/cli": "^7.6.6",
    "@capacitor/core": "^7.6.6",
    "@capacitor/ios": "^7.6.6",
    "@capacitor/local-notifications": "^7.0.7",
    "@revenuecat/purchases-capacitor": "^11.3.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/katex": "^0.16.8",
    "@vitejs/plugin-react": "^5.0.4",
    "dompurify": "^3.4.2",
    "firebase": "^12.12.1",
    "katex": "^0.16.47",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.7.5",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "tsx": {
      "esbuild": "^0.28.1"
    }
  }
}
