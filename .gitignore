# --- Node / build output ---
node_modules
dist
.DS_Store
*.local

# --- Environment files (NEVER commit real keys) ---
.env
.env.*
!.env.example
!**/.env.example
!.env.production.example

# --- IDEs / agents / tooling ---
.idea/
.claude/
.vscode/
.cursor/
*.iml

# --- Firebase CLI local caches ---
.firebase/
firebase-debug.log
firestore-debug.log
firestore-debug.*.log
ui-debug.log

# --- Secrets & cloud credentials (never commit) ---
# Firebase web applet config (use .env instead — this file historically held the same keys)
firebase-applet-config.json
# Firebase Admin SDK service account JSONs (multiple naming conventions)
**/firebase-adminsdk*.json
**/*serviceAccount*.json
**/*service-account*.json
**/*.serviceaccount.json
# Google client configs for mobile (added by Capacitor / native shells)
**/google-services.json
**/GoogleService-Info.plist
# Generic credential / token files
**/credentials.json
**/credentials*.json
**/secrets.json
**/*-credentials.json
**/*.pem
**/*.key
# PKCS containers and Apple developer artifacts
**/*.p8
**/*.p12
**/*.pfx
**/*.mobileprovision
**/*.cer

# --- Generated attribution snapshots ---
THIRD_PARTY_LICENSES.json

# --- Android ---
android/.gradle/
android/**/build/
android/captures/
android/*.iml
android/local.properties
android/keystore.properties
android/**/*.jks
android/**/*.keystore

# --- iOS / Capacitor (generated by `npx cap add ios`) ---
ios/Pods/
ios/App/Pods/
ios/App/build/
ios/DerivedData/
*.xcuserstate
xcuserdata/

# --- Misc ---
coverage/
*.tsbuildinfo
.tmp/
tmp/
*.log
*.sqlite
*.sqlite3
*.db
*.bak
*.swp
*.tmp
uploads/
uploaded-exams/
test-results/
playwright-report/
artifacts/

# --- Temp UI capture output ---
tmp-ui-screenshots/
deliverables/
design-backups/

# The tracked internal note is a public-safe template. Real operator notes
# must use a .local.md suffix or the private subdirectory.
docs/internal/*.local.md
docs/internal/private/
release/
